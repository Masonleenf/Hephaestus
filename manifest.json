{
  "schemaVersion": "1.0",
  "package": "agentlas-core-engine-meta-agent",
  "description": "Portable Markdown-first three-agent meta-agent team for creating single agents, creating multi-agent teams, and packaging existing agents into Agentlas architecture.",
  "entrypoints": {
    "canonical": "AGENTS.md",
    "singleAgent": "agent.md",
    "codexPlugin": "codex/plugins/agentlas-core-engine-meta-agent/.codex-plugin/plugin.json",
    "claudeCommand": ".claude/commands/meta-agent.md",
    "gemini": "GEMINI.md",
    "installer": "scripts/install.sh"
  },
  "coreAgents": [
    "agents/10-single-agent-builder/agent.md",
    "agents/20-multi-agent-team-builder/agent.md",
    "agents/30-agentlas-packager/agent.md"
  ],
  "requiredConcepts": [
    "single-agent-builder",
    "multi-agent-team-builder",
    "agentlas-packager",
    "self-evolving-single-agent",
    "memory-architecture",
    "all-llm-runtime-architecture",
    "runtime-adapters",
    "policy-gate",
    "eval-release-review",
    "public-packaging"
  ],
  "requiredDirectories": [
    "agents",
    "modes",
    "skills",
    ".agents",
    ".agentlas",
    ".claude",
    ".gemini",
    "codex",
    "schemas",
    "templates",
    "docs",
    "scripts"
  ]
}
