{
  "schemaVersion": "1.0",
  "teamId": "valid-team-fixture",
  "name": "Valid Team Fixture",
  "topology": "hub-and-spoke",
  "orchestrator": "00-orchestrator",
  "router": "00-orchestrator",
  "nodes": [
    {
      "id": "00-orchestrator",
      "role": "Orchestrator/HQ",
      "path": "agents/00-orchestrator/agent.md",
      "produces": ["final-answer"]
    },
    {
      "id": "10-researcher",
      "role": "Research Worker",
      "path": "agents/10-researcher/agent.md",
      "produces": ["evidence-notes"]
    },
    {
      "id": "20-analyst",
      "role": "Analysis Worker",
      "path": "agents/20-analyst/agent.md",
      "consumes": ["evidence-notes"],
      "produces": ["scored-synthesis"]
    }
  ],
  "edges": [
    {
      "from": "00-orchestrator",
      "to": "10-researcher",
      "handoff": "collect evidence"
    },
    {
      "from": "10-researcher",
      "to": "20-analyst",
      "handoff": "pass evidence notes"
    },
    {
      "from": "20-analyst",
      "to": "00-orchestrator",
      "handoff": "return scored synthesis"
    }
  ]
}
